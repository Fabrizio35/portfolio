---
interface Props {
  date: string
  title: string
  institution: string
  description: string
}

const { date, description, title, institution } = Astro.props
---

<div
  class="absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -start-1.5 border border-white dark:border-gray-900 dark:bg-gray-700"
>
</div>
<time class="mb-1 text-sm font-normal leading-none text-sky-200/80">{date}</time
>
<h3 class="text-xl font-bold text-yellow-400/90 mt-2">
  {title}
</h3>
<h4 class="font-semibold text-xl text-white pb-4">{institution}</h4>
<p class="text-base font-normal text-gray-300 text-pretty">
  {description}
</p>
