---
interface Props {
  title: string
  description: string
  link?: string
  date: string
  company: string
  technologies: string
}

const { title, description, link, date, company, technologies } = Astro.props
---

<div
  class="absolute w-3 h-3 bg-gray-200 rounded-full mt-1.5 -start-1.5 border border-white dark:border-gray-900 dark:bg-gray-700"
>
</div>
<time class="mb-1 text-sm font-normal leading-none text-sky-200/80">{date}</time
>
<h3 class="text-xl font-bold text-yellow-400/90 mt-2">
  {title}
</h3>
<h4 class="font-semibold text-xl text-white pb-4">{company}</h4>
<p class="mb-4 text-base font-normal text-gray-300 text-pretty">
  {description}
</p>
<p class="mb-4 text-base font-normal text-gray-300 text-pretty">
  {technologies}
</p>
{
  link && (
    <a
      href={link}
      rel="noopener noreferrer"
      target="_blank"
      class="flex items-center w-fit px-4 py-2 text-sm font-medium text-gray-800 bg-gray-100 rounded-lg hover:bg-gray-50 hover:scale-105 transition"
    >
      Saber más
      <svg
        class="w-3 h-3 ms-2 rtl:rotate-180"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 14 10"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 5h12m0 0L9 1m4 4L9 9"
        />
      </svg>
    </a>
  )
}
